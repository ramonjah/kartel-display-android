<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose управляет всем UI-деревом — XML-тема нужна только как
         фон окна до первой композиции (kiosk-режим, без system bars). -->
    <style name="Theme.KartelDisplay" parent="android:Theme.Material.NoActionBar.Fullscreen">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
    </style>

    <!-- Экран запуска (androidx.core.splashscreen) — держит логотип на чёрном
         фоне, пока Compose готовится (pairing/token-check ещё не отрисован);
         раньше в этот момент был просто пустой чёрный экран. Иконка — тот же
         ic_launcher (108dp vector), что уже в лаунчере/баннере ТВ, не новая
         графика. postSplashScreenTheme — куда переключиться сразу после. -->
    <style name="Theme.KartelDisplay.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.KartelDisplay</item>
    </style>
</resources>
